generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page Page?

  @@map("users")
}

model Page {
  id        String  @id @default(uuid())
  slug      String  @unique
  title     String?
  bio       String?
  avatarUrl String? @map("avatar_url")

  snsInstagram String? @map("sns_instagram")
  snsYoutube   String? @map("sns_youtube")
  snsTwitter   String? @map("sns_twitter")
  snsFacebook  String? @map("sns_facebook")
  snsTiktok    String? @map("sns_tiktok")
  snsGithub    String? @map("sns_github")
  snsThreads   String? @map("sns_threads")
  snsLinkedin  String? @map("sns_linkedin")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  links Link[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

model Link {
  id       String  @id @default(uuid())
  title    String
  url      String
  position Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  pageId String @map("page_id")
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("links")
}
